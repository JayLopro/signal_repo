# PA 1차 배포 (production-like)
# - decisions.md §7 RUNBOOK: PA 배포 시 반드시 ENABLE_LLM_ON_PA=false
# - 누락/true이더라도 PA에서는 코드상 LLM 호출 차단 (Phase 4에서 가드 구현)

APP_MODE=production
ENABLE_LLM_ON_PA=false

DJANGO_SECRET_KEY=replace-with-long-random-string
DJANGO_DEBUG=False
ALLOWED_HOSTS=yourname.pythonanywhere.com,localhost,127.0.0.1

# PA 1차에서는 LLM 직접 호출 X — 사전 생성 결과만 조회.
# 키는 비워두거나 미사용. 운영 단계에서 정책 결정 후 채움.
GOOGLE_API_KEY=
OPENAI_API_KEY=
BOK_API_KEY=
